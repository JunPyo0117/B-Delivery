{
  "proxy": {
    "proxy_extra_http_headers": ["X-Centrifugo-Proxy-Secret"],
    "static_http_headers": {
      "X-Centrifugo-Proxy-Secret": "${CENTRIFUGO_PROXY_SECRET}"
    }
  },
  "client": {
    "token": {
      "hmac_secret_key": "${CENTRIFUGO_CLIENT_TOKEN_HMAC_SECRET_KEY}"
    },
    "allowed_origins": ["*"],
    "proxy": {
      "connect": {
        "enabled": true,
        "endpoint": "http://host.docker.internal:3000/api/centrifugo/connect",
        "timeout": "3s"
      }
    }
  },
  "channel": {
    "proxy": {
      "subscribe": {
        "endpoint": "http://host.docker.internal:3000/api/centrifugo/subscribe",
        "timeout": "3s"
      },
      "publish": {
        "endpoint": "http://host.docker.internal:3000/api/centrifugo/publish",
        "timeout": "5s"
      }
    },
    "without_namespace": {
      "history_size": 20,
      "history_ttl": "120s",
      "force_recovery": true
    },
    "namespaces": [
      {
        "name": "chat",
        "subscribe_proxy_enabled": true,
        "publish_proxy_enabled": true,
        "allow_publish_for_client": true
      },
      {
        "name": "rider_location",
        "subscribe_proxy_enabled": true,
        "history_size": 0,
        "history_ttl": "0s",
        "force_recovery": false
      }
    ]
  },
  "rpc": {
    "proxy": {
      "endpoint": "http://host.docker.internal:3000/api/centrifugo/rpc",
      "timeout": "3s"
    },
    "without_namespace": {
      "proxy_enabled": true
    },
    "namespaces": [
      { "name": "typing", "proxy_enabled": true },
      { "name": "message", "proxy_enabled": true },
      { "name": "location", "proxy_enabled": true },
      { "name": "delivery", "proxy_enabled": true }
    ]
  },
  "http_api": {
    "key": "${CENTRIFUGO_HTTP_API_KEY}"
  },
  "admin": {
    "enabled": true,
    "password": "${CENTRIFUGO_ADMIN_PASSWORD}",
    "secret": "${CENTRIFUGO_ADMIN_SECRET}"
  }
}
